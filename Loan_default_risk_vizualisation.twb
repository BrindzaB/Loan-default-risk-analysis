    <worksheet name='Default Rate by Segment'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>Default Rate by Segments</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='risk_by_segments_overview' name='federated.182a0aq0k2y0kj143ro1x034g4my' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Global Default Rate' datatype='real' default-format='p0.00%' name='[Parameter 1]' param-domain-type='any' role='measure' type='quantitative' value='0.1161'>
              <calculation class='tableau' formula='0.1161' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.182a0aq0k2y0kj143ro1x034g4my'>
            <column caption='Avg_Default_Calc' datatype='string' name='[Calculation_2940203677978624]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [default_rate] &gt; { FIXED : AVG([default_rate])}&#10;THEN &quot;Above Avg&quot;&#10;ELSE &quot;Below Avg&quot;&#10;END' />
            </column>
            <column caption='Default Rate' datatype='real' name='[default_rate]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_2940203677978624]' derivation='None' name='[none:Calculation_2940203677978624:nk]' pivot='key' type='nominal' />
            <column-instance column='[segment_type]' derivation='None' name='[none:segment_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[segment_value]' derivation='None' name='[none:segment_value:nk]' pivot='key' type='nominal' />
